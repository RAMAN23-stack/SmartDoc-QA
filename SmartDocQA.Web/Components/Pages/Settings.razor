@page "/settings"
@using SmartDocQA.Core.Models
@inject DocumentSessionState SessionState
@inject ISnackbar Snackbar

<PageTitle>Settings - SmartDoc QA</PageTitle>

<!-- Hero -->
<div class="settings-hero mb-6">
    <h1>⚙️ AI Provider Settings</h1>
    <p>Configure which AI engine powers your document queries</p>
</div>

<!-- Current Config Banner -->
<div class="config-strip mb-5">
    <div class="config-item">
        <span>🤖</span><strong>Active:</strong> @SessionState.SelectedProvider
    </div>
    <div class="config-divider"></div>
    <div class="config-item">
        <span>📦</span><strong>Model:</strong> @SessionState.SelectedModel
    </div>
    <div class="config-divider"></div>
    <div class="config-item">
        <span>🌡️</span><strong>Temperature:</strong> @SessionState.Temperature.ToString("F1")
    </div>
</div>

<!-- Provider Cards -->
<div class="settings-section-title mb-3">
    <MudIcon Icon="@Icons.Material.Filled.Power" Style="font-size:1rem;color:#6366f1;" />
    Choose Your AI Provider
</div>
<MudGrid Spacing="3" Class="mb-6">

    <!-- Groq -->
    <MudItem xs="12" sm="6" md="6">
        <div class="provider-card @(SessionState.SelectedProvider == AIProvider.Groq ? "provider-card-active" : "")"
             @onclick="() => SelectProvider(AIProvider.Groq)">
            <div class="provider-card-header provider-header-groq">
                <span class="provider-icon">🔴</span>
                <div>
                    <div class="provider-name">Groq</div>
                    <div class="provider-tag">Free & Ultra-Fast</div>
                </div>
                @if (SessionState.SelectedProvider == AIProvider.Groq)
                {
                    <span class="active-badge">✅ Active</span>
                }
            </div>
            <div class="provider-card-body">
                <p class="provider-desc">LPU-powered inference — fastest available. Best for quick Q&A and demos.</p>
                <div class="model-chips">
                    @foreach (var m in groqModels)
                    {
                        <span class="model-chip @(SessionState.SelectedModel == m && SessionState.SelectedProvider == AIProvider.Groq ? "model-chip-active" : "")"
                              @onclick:stopPropagation="true"
                              @onclick="() => SelectModel(AIProvider.Groq, m)">@m</span>
                    }
                </div>
                <div class="provider-meta mt-3">
                    <span class="meta-badge meta-green">✅ Free Tier</span>
                    <span class="meta-badge meta-blue">🚀 Fastest</span>
                    <span class="meta-badge meta-purple">🔑 API Key Needed</span>
                </div>
            </div>
        </div>
    </MudItem>

    <!-- OpenAI -->
    <MudItem xs="12" sm="6" md="6">
        <div class="provider-card @(SessionState.SelectedProvider == AIProvider.OpenAI ? "provider-card-active" : "")"
             @onclick="() => SelectProvider(AIProvider.OpenAI)">
            <div class="provider-card-header provider-header-openai">
                <span class="provider-icon">🟢</span>
                <div>
                    <div class="provider-name">OpenAI</div>
                    <div class="provider-tag">GPT-4o & GPT-4o-mini</div>
                </div>
                @if (SessionState.SelectedProvider == AIProvider.OpenAI)
                {
                    <span class="active-badge">✅ Active</span>
                }
            </div>
            <div class="provider-card-body">
                <p class="provider-desc">World-class GPT models. Excellent reasoning and long-context understanding.</p>
                <div class="model-chips">
                    @foreach (var m in openaiModels)
                    {
                        <span class="model-chip @(SessionState.SelectedModel == m && SessionState.SelectedProvider == AIProvider.OpenAI ? "model-chip-active" : "")"
                              @onclick:stopPropagation="true"
                              @onclick="() => SelectModel(AIProvider.OpenAI, m)">@m</span>
                    }
                </div>
                <div class="provider-meta mt-3">
                    <span class="meta-badge meta-yellow">💰 Paid API</span>
                    <span class="meta-badge meta-blue">🧠 Best Reasoning</span>
                    <span class="meta-badge meta-purple">🔑 API Key Needed</span>
                </div>
            </div>
        </div>
    </MudItem>

    <!-- Google Gemini -->
    <MudItem xs="12" sm="6" md="6">
        <div class="provider-card @(SessionState.SelectedProvider == AIProvider.Google ? "provider-card-active" : "")"
             @onclick="() => SelectProvider(AIProvider.Google)">
            <div class="provider-card-header provider-header-google">
                <span class="provider-icon">🔵</span>
                <div>
                    <div class="provider-name">Google Gemini</div>
                    <div class="provider-tag">Gemini 2.0 Flash & Pro</div>
                </div>
                @if (SessionState.SelectedProvider == AIProvider.Google)
                {
                    <span class="active-badge">✅ Active</span>
                }
            </div>
            <div class="provider-card-body">
                <p class="provider-desc">Google's multimodal model family with generous free tier. Great for documents.</p>
                <div class="model-chips">
                    @foreach (var m in googleModels)
                    {
                        <span class="model-chip @(SessionState.SelectedModel == m && SessionState.SelectedProvider == AIProvider.Google ? "model-chip-active" : "")"
                              @onclick:stopPropagation="true"
                              @onclick="() => SelectModel(AIProvider.Google, m)">@m</span>
                    }
                </div>
                <div class="provider-meta mt-3">
                    <span class="meta-badge meta-green">✅ Free Tier</span>
                    <span class="meta-badge meta-blue">📄 Great for Docs</span>
                    <span class="meta-badge meta-purple">🔑 API Key Needed</span>
                </div>
            </div>
        </div>
    </MudItem>

    <!-- Ollama -->
    <MudItem xs="12" sm="6" md="6">
        <div class="provider-card @(SessionState.SelectedProvider == AIProvider.Ollama ? "provider-card-active" : "")"
             @onclick="() => SelectProvider(AIProvider.Ollama)">
            <div class="provider-card-header provider-header-ollama">
                <span class="provider-icon">🏠</span>
                <div>
                    <div class="provider-name">Ollama (Local)</div>
                    <div class="provider-tag">100% Private & Free</div>
                </div>
                @if (SessionState.SelectedProvider == AIProvider.Ollama)
                {
                    <span class="active-badge">✅ Active</span>
                }
            </div>
            <div class="provider-card-body">
                <p class="provider-desc">Run models entirely on your machine. No API key, no data leaves your device.</p>
                <div class="model-chips">
                    @foreach (var m in ollamaModels)
                    {
                        <span class="model-chip @(SessionState.SelectedModel == m && SessionState.SelectedProvider == AIProvider.Ollama ? "model-chip-active" : "")"
                              @onclick:stopPropagation="true"
                              @onclick="() => SelectModel(AIProvider.Ollama, m)">@m</span>
                    }
                </div>
                <div class="provider-meta mt-3">
                    <span class="meta-badge meta-green">✅ 100% Free</span>
                    <span class="meta-badge meta-green">🔒 Private</span>
                    <span class="meta-badge meta-gray">🖥️ Local GPU/CPU</span>
                </div>
            </div>
        </div>
    </MudItem>
</MudGrid>

<!-- Temperature Slider -->
<MudPaper Class="pa-5 mb-6 temp-card" Elevation="0">
    <div class="temp-title">🌡️ Creativity / Temperature</div>
    <div class="temp-subtitle">Controls how creative the AI is. Low = precise facts, High = creative/exploratory.</div>

    <div class="temp-slider-row">
        <span class="temp-label-end">🎯 Precise (0.0)</span>
        <MudSlider T="double"
                   Value="SessionState.Temperature"
                   ValueChanged="OnTemperatureChanged"
                   Min="0.0" Max="1.0" Step="0.1"
                   Color="Color.Secondary"
                   Class="flex-grow-1 mx-4" />
        <span class="temp-label-end">🎨 Creative (1.0)</span>
    </div>

    <div class="text-center mt-3">
        <span class="temp-value-chip">
            @SessionState.Temperature.ToString("F1") — @GetTemperatureLabel()
        </span>
    </div>

    <div class="temp-hints mt-4">
        <div class="temp-hint-item"><strong>0.0</strong> Deterministic, best for factual document Q&amp;A</div>
        <div class="temp-hint-item"><strong>0.3–0.5</strong> Balanced, good for summaries and analysis</div>
        <div class="temp-hint-item"><strong>0.7–1.0</strong> Creative, good for brainstorming</div>
    </div>
</MudPaper>


<!-- Save Button -->
<div class="text-center mt-4 mb-8">
    <button class="save-settings-btn" @onclick="SaveSettings">
        <MudIcon Icon="@Icons.Material.Filled.Save" Style="font-size:1.1rem;" />
        Save Settings
    </button>
</div>

<style>
    /* ── Hero ── */
    .settings-hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
        color: white;
        padding: 2.75rem 2rem 2.5rem;
        border-radius: 20px;
        text-align: center;
    }
    .settings-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 70% 50%, rgba(99,102,241,0.35), transparent 60%);
        pointer-events: none;
    }
    .settings-hero h1 { font-size: 2.2rem; font-weight: 800; margin: 0 0 0.5rem; letter-spacing: -0.5px; position: relative; }
    .settings-hero p  { opacity: 0.75; font-size: 1rem; margin: 0; position: relative; }

    /* ── Current Config Strip ── */
    .config-strip {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(12px) saturate(180%);
        -webkit-backdrop-filter: blur(12px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 14px;
        padding: 0.85rem 1.25rem;
        box-shadow: 0 8px 32px rgba(31, 38, 135, 0.04), inset 0 1px 0 rgba(255, 255, 255, 0.3);
        flex-wrap: wrap;
        gap: 8px;
    }
    .mud-theme-dark .config-strip {
        background: rgba(13, 22, 42, 0.55);
        border-color: rgba(255, 255, 255, 0.08);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .config-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.86rem;
        color: #475569;
    }
    .config-item strong { color: #1e293b; font-weight: 700; }
    .config-divider { width: 1px; height: 18px; background: #e2e8f0; margin: 0 4px; }

    /* ── Section Title ── */
    .settings-section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ── Provider Cards ── */
    .provider-card {
        border: 1.5px solid rgba(255, 255, 255, 0.5);
        border-radius: 18px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        box-shadow: 0 8px 32px rgba(31, 38, 135, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }
    .provider-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 36px rgba(99, 102, 241, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.5);
        border-color: rgba(99, 102, 241, 0.3);
    }
    .provider-card-active {
        border-color: #6366f1 !important;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2), 0 12px 36px rgba(99, 102, 241, 0.15) !important;
    }
    .mud-theme-dark .provider-card {
        background: rgba(13, 22, 42, 0.55);
        border-color: rgba(255, 255, 255, 0.07);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .mud-theme-dark .provider-card:hover {
        border-color: rgba(99, 102, 241, 0.35);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.35);
    }

    .provider-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px 20px;
        color: white;
        position: relative;
        overflow: hidden;
    }
    .provider-card-header::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
        pointer-events: none;
    }
    .provider-header-groq   { background: linear-gradient(135deg, #f55036, #ff6b35); }
    .provider-header-openai { background: linear-gradient(135deg, #10a37f, #00765a); }
    .provider-header-google { background: linear-gradient(135deg, #4285f4, #1a56cc); }
    .provider-header-ollama { background: linear-gradient(135deg, #6366f1, #4338ca); }

    .provider-icon {
        font-size: 1.8rem;
        flex-shrink: 0;
        width: 48px; height: 48px;
        background: rgba(255,255,255,0.15);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        backdrop-filter: blur(4px);
    }
    .provider-name { font-size: 1.1rem; font-weight: 800; }
    .provider-tag  { font-size: 0.76rem; opacity: 0.82; font-weight: 500; margin-top: 1px; }
    .active-badge  {
        position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
        background: rgba(255,255,255,0.22);
        backdrop-filter: blur(4px);
        padding: 4px 12px; border-radius: 100px;
        font-size: 0.76rem; font-weight: 700;
        border: 1px solid rgba(255,255,255,0.3);
        z-index: 1;
    }

    .provider-card-body { padding: 16px 20px 18px; }
    .provider-desc { font-size: 0.84rem; color: #64748b; margin-bottom: 12px; line-height: 1.5; }

    .model-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .model-chip {
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.74rem;
        font-weight: 600;
        background: #f1f5f9;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        cursor: pointer;
        transition: all 0.15s;
    }
    .model-chip:hover { background: #e0e7ff; color: #4338ca; border-color: #a5b4fc; }
    .model-chip-active { background: #6366f1 !important; color: white !important; border-color: #4338ca !important; box-shadow: 0 2px 8px rgba(99,102,241,0.3); }

    .provider-meta { display: flex; flex-wrap: wrap; gap: 6px; }
    .meta-badge {
        padding: 3px 10px; border-radius: 100px;
        font-size: 0.71rem; font-weight: 700;
        letter-spacing: 0.2px;
    }
    .meta-green  { background: #dcfce7; color: #15803d; }
    .meta-blue   { background: #dbeafe; color: #1d4ed8; }
    .meta-yellow { background: #fef3c7; color: #92400e; }
    .meta-purple { background: #ede9fe; color: #5b21b6; }
    .meta-gray   { background: #f1f5f9; color: #475569; }

    /* ── Temperature Card ── */
    .temp-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 1.5px solid rgba(255, 255, 255, 0.5);
        border-radius: 18px !important;
        box-shadow: 0 8px 32px rgba(31, 38, 135, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }
    .mud-theme-dark .temp-card {
        background: rgba(13, 22, 42, 0.55);
        border-color: rgba(255, 255, 255, 0.07);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .temp-title {
        font-size: 1rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }
    .temp-subtitle { font-size: 0.84rem; color: #64748b; margin-bottom: 1.25rem; }
    .temp-slider-row { display: flex; align-items: center; gap: 10px; }
    .temp-label-end { font-size: 0.78rem; color: #64748b; white-space: nowrap; font-weight: 500; }
    .temp-value-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        font-size: 0.9rem;
        font-weight: 700;
        padding: 8px 20px;
        border-radius: 100px;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
    }
    .temp-hints { display: flex; flex-direction: column; gap: 0; }
    .temp-hint-item {
        font-size: 0.8rem;
        color: #64748b;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .temp-hint-item strong { color: #4f46e5; }

    /* ── Save Button ── */
    .save-settings-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white !important;
        font-size: 1.05rem;
        font-weight: 700;
        padding: 1rem 3rem;
        border-radius: 14px;
        border: none;
        cursor: pointer;
        box-shadow: 0 6px 24px rgba(99,102,241,0.35);
        transition: all 0.3s;
        text-transform: none !important;
    }
    .save-settings-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(99,102,241,0.45); }
</style>

@code {
    private readonly List<string> groqModels   = new() { "llama-3.3-70b-versatile", "llama-3.1-70b-versatile", "mixtral-8x7b-32768", "gemma2-9b-it" };
    private readonly List<string> openaiModels = new() { "gpt-4o-mini", "gpt-4o", "gpt-4-turbo", "gpt-3.5-turbo" };
    private readonly List<string> googleModels = new() { "gemini-2.0-flash-exp", "gemini-1.5-pro", "gemini-1.5-flash" };
    private readonly List<string> ollamaModels = new() { "llama3.2", "llama3.1", "mistral", "codellama", "gemma2" };

    private const string EnvTemplate =
@"# SmartDoc QA — API Keys
# Place this file at: SmartDocQA.Web/.env

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx

# Ollama runs locally — no key needed
# Make sure Ollama is running: ollama serve";

    private void SelectProvider(AIProvider provider)
    {
        SessionState.SelectedProvider = provider;
        // Auto-select first model for provider
        var models = provider switch
        {
            AIProvider.Groq   => groqModels,
            AIProvider.OpenAI => openaiModels,
            AIProvider.Google => googleModels,
            AIProvider.Ollama => ollamaModels,
            _ => new List<string>()
        };
        SessionState.SelectedModel = models.FirstOrDefault() ?? "";
        SessionState.NotifyStateChanged();
    }

    private void SelectModel(AIProvider provider, string model)
    {
        SessionState.SelectedProvider = provider;
        SessionState.SelectedModel = model;
        SessionState.NotifyStateChanged();
    }

    private void OnTemperatureChanged(double temp)
    {
        SessionState.Temperature = Math.Round(temp, 1);
        SessionState.NotifyStateChanged();
    }

    private string GetTemperatureLabel() => SessionState.Temperature switch
    {
        <= 0.0 => "Deterministic",
        <= 0.2 => "Very Precise",
        <= 0.4 => "Factual",
        <= 0.6 => "Balanced",
        <= 0.8 => "Creative",
        _      => "Very Creative"
    };

    private void SaveSettings()
    {
        SessionState.NotifyStateChanged();
        Snackbar.Add($"✅ Settings saved! Using {SessionState.SelectedProvider} · {SessionState.SelectedModel}", Severity.Success);
    }
}
