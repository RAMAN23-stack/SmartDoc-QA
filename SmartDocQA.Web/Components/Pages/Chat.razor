@page "/chat"
@using SmartDocQA.Core.Interfaces
@using SmartDocQA.Core.Models
@using SmartDocQA.Infrastructure.AI
@using System.Text.RegularExpressions
@inject ILLMService LLMService
@inject IVectorStore VectorStore
@inject DocumentSessionState SessionState
@inject SqliteQueryEngine SqliteEngine
@inject IJSRuntime JS

<PageTitle>Chat - SmartDoc QA</PageTitle>

<!-- No documents guard -->
@if (!SessionState.ExtractedDocuments.Any() && SessionState.TabularData == null)
{
    <div class="no-docs-screen">
        <div class="no-docs-icon">📂</div>
        <h2>No Documents Loaded</h2>
        <p>Please upload documents first before starting a conversation.</p>
        <a href="/upload" class="upload-cta-btn mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-elevation-2">
            <span class="mud-button-label">📤 Go to Upload</span>
        </a>
    </div>
}
else
{
    <div class="chat-outer-wrapper">

        <!-- Chat Header -->
        <div class="chat-header-bar">
            <div class="chat-header-info">
                <span class="chat-header-icon">💬</span>
                <div>
                    <div class="chat-header-title">SmartDoc AI Chat</div>
                    <div class="chat-header-sub">
                        @GetDataSourceSummary()
                    </div>
                </div>
            </div>
            <div class="chat-header-actions">
                <button class="icon-btn" @onclick="ClearChat" title="Clear chat">🗑️</button>
            </div>
        </div>

        <!-- Data Source Chips -->
        <div class="source-chips-row">
            @if (SessionState.TabularData != null)
            {
                <span class="source-chip chip-green">
                    @(SessionState.TabularFileType == "Excel" ? "📊" : "📋") @SessionState.TabularDocument?.FileName
                    · @SessionState.TabularData.Rows.Count rows
                </span>
            }
            @foreach (var doc in SessionState.ExtractedDocuments)
            {
                <span class="source-chip chip-blue">
                    @GetFileIcon(doc.FileType) @doc.FileName
                </span>
            }
        </div>

        <!-- Messages Window -->
        <div class="chat-messages-window" id="chatScrollArea">
            @if (!messages.Any())
            {
                <!-- Welcome / Suggestion Panel -->
                <div class="chat-welcome">
                    <div class="welcome-icon">🤖</div>
                    <h3>Ready to Answer Questions!</h3>
                    <p>Ask anything about your uploaded documents.</p>

                    @if (SessionState.TabularData != null)
                    {
                        <div class="suggestions-group">
                            <div class="suggestions-label">📊 Try asking about your data:</div>
                            <div class="suggestions-grid">
                                @foreach (var hint in GetTabularHints())
                                {
                                    <button class="suggestion-chip" @onclick="() => UseSuggestion(hint)">@hint</button>
                                }
                            </div>
                        </div>
                    }

                    @if (SessionState.ExtractedDocuments.Any())
                    {
                        <div class="suggestions-group">
                            <div class="suggestions-label">📄 Try asking about your documents:</div>
                            <div class="suggestions-grid">
                                <button class="suggestion-chip" @onclick='() => UseSuggestion("Summarize all documents")'>Summarize all documents</button>
                                <button class="suggestion-chip" @onclick='() => UseSuggestion("What are the key points?")'>What are the key points?</button>
                                <button class="suggestion-chip" @onclick='() => UseSuggestion("What is the main topic?")'>What is the main topic?</button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    @if (msg.Role == "user")
                    {
                        <div class="msg-row msg-user">
                            <div class="msg-bubble msg-bubble-user">
                                <div class="msg-label">👤 You</div>
                                <div class="msg-text">@msg.Content</div>
                            </div>
                        </div>
                    }
                    else if (msg.Role == "assistant")
                    {
                        <div class="msg-row msg-ai">
                            <div class="msg-avatar">🤖</div>
                            <div class="msg-bubble msg-bubble-ai">
                                <div class="msg-label">AI · @SessionState.SelectedProvider · @SessionState.SelectedModel</div>
                                <div class="msg-text msg-text-ai">@((MarkupString)FormatAIResponse(msg.Content))</div>
                                @if (!string.IsNullOrEmpty(msg.SourceInfo))
                                {
                                    <div class="msg-source">📎 @msg.SourceInfo</div>
                                }
                            </div>
                        </div>
                    }
                    else if (msg.Role == "thinking")
                    {
                        <div class="msg-row msg-ai">
                            <div class="msg-avatar thinking-avatar">🤖</div>
                            <div class="msg-bubble msg-bubble-thinking">
                                <div class="msg-label">AI · Thinking...</div>
                                <div class="thinking-dots"><span></span><span></span><span></span></div>
                                <div class="msg-text" style="font-size:0.82rem; opacity:0.7;">@msg.Content</div>
                            </div>
                        </div>
                    }
                }
            }
        </div>

        <!-- Input Bar -->
        <div class="chat-input-bar">
            <div class="input-wrapper">
                <textarea class="chat-textarea"
                          @bind="userInput"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          placeholder="Ask about your documents… (Enter to send, Shift+Enter for newline)"
                          rows="1"
                          id="chatInput"
                          disabled="@isProcessing"></textarea>
                <button class="send-btn @(isProcessing ? "send-btn-loading" : "")"
                        @onclick="SendMessage"
                        disabled="@isProcessing"
                        title="Send">
                    @if (isProcessing)
                    {
                        <span class="send-spinner"></span>
                    }
                    else
                    {
                        <span>➤</span>
                    }
                </button>
            </div>
            <div class="input-footer">
                <span>Provider: <strong>@SessionState.SelectedProvider</strong> · Model: <strong>@SessionState.SelectedModel</strong> · Temp: <strong>@SessionState.Temperature.ToString("F1")</strong></span>
                @if (isProcessing)
                {
                    <span class="processing-status">⏳ @processingStage</span>
                }
            </div>
        </div>
    </div>
}

<style>
    /* ── No Docs Screen ── */
