    .chat-header-info { display: flex; align-items: center; gap: 1rem; position: relative; z-index: 1; }
    .chat-header-icon {
        font-size: 1.5rem;
        width: 44px; height: 44px;
        background: rgba(255,255,255,0.12);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
