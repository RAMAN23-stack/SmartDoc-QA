    }
    .chat-header-title { font-size: 1.05rem; font-weight: 700; }
    .chat-header-sub   { font-size: 0.75rem; opacity: 0.75; }
    .chat-header-actions { position: relative; z-index: 1; }
    .icon-btn {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        font-size: 1.1rem;
        cursor: pointer;
        padding: 6px 10px;
        transition: background 0.2s;
        backdrop-filter: blur(6px);
    }
    .icon-btn:hover { background: rgba(255,255,255,0.2); }

    /* ── Source Chips ── */
    .source-chips-row {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 8px 16px;
        background: #fafbff;
        border-bottom: 1px solid #e8ecf6;
        flex-shrink: 0;
    }
    .source-chip {
        padding: 3px 12px;
        border-radius: 100px;
        font-size: 0.76rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .chip-green { background: #dcfce7; color: #15803d; border: 1px solid #86efac; }
    .chip-blue  { background: #dbeafe; color: #1d4ed8; border: 1px solid #93c5fd; }

    /* ── Messages Window ── */
    .chat-messages-window {
        flex: 1;
        overflow-y: auto;
        padding: 1.75rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        background: transparent;
        scroll-behavior: smooth;
    }

    /* Welcome Panel */
    .chat-welcome {
        text-align: center;
        margin: auto;
        max-width: 580px;
        animation: fadeSlideUp 0.5s ease;
    }
    .welcome-icon {
        font-size: 4rem;
        margin-bottom: 0.75rem;
        filter: drop-shadow(0 4px 12px rgba(99,102,241,0.2));
    }
    .chat-welcome h3 { font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: 0.4rem; }
    .chat-welcome p  { color: #64748b; margin-bottom: 1.5rem; font-size: 0.95rem; }

    .suggestions-group { margin-bottom: 1.25rem; text-align: left; }
    .suggestions-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }
    .suggestions-grid { display: flex; flex-wrap: wrap; gap: 8px; }
    .suggestion-chip {
        background: rgba(255, 255, 255, 0.45);
        border: 1.5px solid rgba(99, 102, 241, 0.25);
        color: #4f46e5;
        padding: 7px 16px;
        border-radius: 100px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(99,102,241,0.08);
        backdrop-filter: blur(8px);
    }
    .suggestion-chip:hover { background: rgba(99, 102, 241, 0.1); border-color: #6366f1; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99,102,241,0.15); }
    .mud-theme-dark .suggestion-chip {
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.08);
        color: #818cf8;
    }
    .mud-theme-dark .suggestion-chip:hover {
        background: rgba(99, 102, 241, 0.25);
        border-color: #818cf8;
    }

    /* Message Rows */
    .msg-row { display: flex; align-items: flex-start; gap: 10px; animation: fadeSlideUp 0.25s ease; }
    .msg-user  { justify-content: flex-end; }
    .msg-ai    { justify-content: flex-start; }
    .msg-avatar {
        font-size: 1.5rem;
        flex-shrink: 0;
        width: 38px; height: 38px;
        background: linear-gradient(135deg, #1e1b4b, #312e81);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }
    .thinking-avatar { animation: pulse-glow 1.5s ease-in-out infinite; }

    /* Bubbles */
    .msg-bubble {
        max-width: 72%;
        padding: 12px 16px;
        border-radius: 18px;
        line-height: 1.65;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    }
    .msg-bubble-user {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        border-bottom-right-radius: 4px;
    }
    .msg-bubble-ai {
        background: rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: #1e293b;
        border-bottom-left-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.5);
    }
    .mud-theme-dark .msg-bubble-ai {
        background: rgba(20, 30, 55, 0.65);
        border-color: rgba(255, 255, 255, 0.06);
        color: #f1f5f9;
    }
    .msg-bubble-thinking {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(10px);
        border: 2px dashed rgba(99, 102, 241, 0.25);
        border-bottom-left-radius: 4px;
        color: #64748b;
    }
    .mud-theme-dark .msg-bubble-thinking {
        background: rgba(20, 30, 55, 0.45);
        border-color: rgba(99, 102, 241, 0.35);
    }
    .msg-label {
        font-size: 0.68rem;
        font-weight: 700;
        opacity: 0.6;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }
    .msg-text { font-size: 0.94rem; white-space: pre-wrap; word-break: break-word; }
    .msg-text-ai pre { background: #f1f5f9; padding: 12px; border-radius: 8px; font-size: 0.82rem; overflow-x: auto; margin: 8px 0; }
    .msg-text-ai code { background: #e0e7ff; color: #3730a3; padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }
    .msg-text-ai table { border-collapse: collapse; width: 100%; font-size: 0.82rem; margin: 8px 0; }
    .msg-text-ai th, .msg-text-ai td { border: 1px solid #e2e8f0; padding: 6px 10px; }
    .msg-text-ai th { background: #f1f5f9; font-weight: 700; }
    .msg-source {
        font-size: 0.7rem;
        color: #6366f1;
        margin-top: 8px;
        border-top: 1px solid rgba(99,102,241,0.15);
        padding-top: 6px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Thinking Dots */
    .thinking-dots { display: flex; gap: 5px; margin: 8px 0; }
    .thinking-dots span {
        width: 8px; height: 8px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-radius: 50%;
        animation: bounce 1.2s ease-in-out infinite;
    }
    .thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
    .thinking-dots span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-8px); } }
    @@keyframes fadeSlideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes pulse-glow { 0%,100% { box-shadow: 0 0 0 0 rgba(99,102,241,0.3); } 50% { box-shadow: 0 0 0 6px transparent; } }

    .chat-input-bar {
        padding: 1rem 1.25rem 1.1rem;
        background: rgba(255, 255, 255, 0.35);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-top: 1px solid rgba(255, 255, 255, 0.4);
        flex-shrink: 0;
    }
    .mud-theme-dark .chat-input-bar {
        background: rgba(13, 22, 42, 0.35);
        border-top-color: rgba(255, 255, 255, 0.06);
    }
    .input-wrapper { display: flex; gap: 10px; align-items: flex-end; }
    .chat-textarea {
        flex: 1;
        resize: none;
        border: 2px solid #c7d2fe;
        border-radius: 14px;
        padding: 12px 16px;
        font-size: 0.94rem;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        max-height: 120px;
        overflow-y: auto;
        line-height: 1.5;
        color: #1e293b;
        background: #fafbff;
    }
    .chat-textarea:focus {
        border-color: #6366f1;
        background: white;
        box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }
    .chat-textarea:disabled { background: #f8fafc; color: #94a3b8; }
    .send-btn {
        width: 48px; height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.2s;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
    }
    .send-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(99,102,241,0.45); }
    .send-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .send-spinner {
        width: 18px; height: 18px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .input-footer {
        display: flex;
        justify-content: space-between;
        font-size: 0.73rem;
        color: #94a3b8;
        margin-top: 6px;
        padding: 0 4px;
    }
    .processing-status { color: #6366f1; font-weight: 600; }
</style>

@code {
    private class ExtChatMessage
    {
        public string Role { get; set; } = "";        // user | assistant | thinking
        public string Content { get; set; } = "";
        public string SourceInfo { get; set; } = "";
    }

    private List<ExtChatMessage> messages = new();
    private string userInput = "";
    private bool isProcessing = false;
    private string processingStage = "";

    // Excel column letters A–Z → 0-based index
    private static readonly Regex CellRefRegex = new(@"\b([A-Za-z]{1,2})(\d+)\b", RegexOptions.Compiled);

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void UseSuggestion(string suggestion)
    {
        userInput = suggestion;
        StateHasChanged();
    }

    private void ClearChat()
    {
        messages.Clear();
        StateHasChanged();
    }

    private async Task SendMessage()
    {
        var raw = userInput.Trim();
        if (string.IsNullOrWhiteSpace(raw)) return;

        // Normalise question
        var question = NormalizeQuestion(raw);

        messages.Add(new ExtChatMessage { Role = "user", Content = raw });
        userInput = "";
        isProcessing = true;
        StateHasChanged();
        await ScrollToBottom();

        // Thinking indicator
        var thinkMsg = new ExtChatMessage { Role = "thinking", Content = "Analysing query..." };
        messages.Add(thinkMsg);
        StateHasChanged();
        await ScrollToBottom();

        string answer = "";
        string sourceInfo = "";

        try
        {
            bool isMultiDoc = SessionState.ExtractedDocuments.Count > 1;

            // ──────────────────────────────────────────────
            // 1️⃣  Tabular route: Excel/CSV (Only for single doc)
            // ──────────────────────────────────────────────
            if (!isMultiDoc && SessionState.TabularData != null && IsTabularQuestion(question))
            {
                thinkMsg.Content = "Generating SQL query for tabular data...";
                StateHasChanged();

                // Build schema context
                var columns = string.Join(", ",
                    SessionState.TabularData.Columns.Cast<System.Data.DataColumn>()
                        .Select(c => $"\"{c.ColumnName}\""));

                var schemaContext = $"Table name: df\nColumns: {columns}\nRows: {SessionState.TabularData.Rows.Count}";

                // Ask LLM for a SQL query
                var sqlPrompt = $@"You are a SQLite expert. Given this table schema:
{schemaContext}

Write a single SQLite SELECT query to answer: ""{question}""

Rules:
- Use only SELECT statements
- Table name is exactly: df
- Column names are case-sensitive — use them exactly as shown
- Return ONLY the SQL query, no explanation, no markdown, no backticks
- If looking for a specific cell or row, use WHERE clause";

                thinkMsg.Content = "Running SQL query on data...";
                StateHasChanged();

                var sqlQuery = await LLMService.GetAnswerAsync(
                    sqlPrompt, schemaContext,
                    SessionState.SelectedProvider, SessionState.SelectedModel);

                if (sqlQuery.Contains("API Error") || sqlQuery.Contains("Error:") || sqlQuery.Contains("Rate limit") || sqlQuery.Contains("TooManyRequests"))
                {
                    answer = sqlQuery;
                    sourceInfo = "⚠️ AI Provider Error";
                }
                else
                {
                    // Execute the SQL
                    try
                    {
                        var queryResult = SqliteEngine.ExecuteQuery(sqlQuery.Trim());

                        thinkMsg.Content = "Interpreting results...";
                        StateHasChanged();

                        var interpretPrompt = $@"The user asked: ""{question}""
SQL query used: {sqlQuery.Trim()}
Query result:
{queryResult}

Give a clear, direct, human-friendly answer. If it's a table, format it nicely.";

                        answer = await LLMService.GetAnswerAsync(
                            interpretPrompt, queryResult,
                            SessionState.SelectedProvider, SessionState.SelectedModel);

                        sourceInfo = $"📊 Tabular Query · {SessionState.TabularDocument?.FileName}";
                    }
                    catch (Exception sqlEx)
                    {
                        // Fallback to content search on SQL failure
                        var fallbackContext = SessionState.TabularDocument?.Content ?? "";
                        answer = await LLMService.GetAnswerAsync(question, fallbackContext,
                            SessionState.SelectedProvider, SessionState.SelectedModel);
                        sourceInfo = $"📄 Content Search · {SessionState.TabularDocument?.FileName} (SQL failed: {sqlEx.Message})";
                    }
                }
            }
            // ──────────────────────────────────────────────
            // 2️⃣  Image Intelligence & OCR route (Only for single doc)
            // ──────────────────────────────────────────────
            else if (!isMultiDoc && SessionState.IsImageLoaded)
            {
                thinkMsg.Content = "Analyzing image with OCR Intelligence Engine...";
                StateHasChanged();

                var imageSystemPrompt = @"You are an Advanced Image Intelligence and OCR Analysis Engine.

Your task is to analyze uploaded images and answer user questions using ONLY information visible in the image.

IMPORTANT:
This prompt applies ONLY to image files such as PNG, JPG, JPEG, BMP, TIFF, Screenshots, Photos, Scanned Images.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRIMARY OBJECTIVE
Extract all visible information from the uploaded image and answer user questions accurately.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
STRICT RULES
