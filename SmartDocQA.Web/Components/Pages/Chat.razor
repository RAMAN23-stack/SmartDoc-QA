        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
        gap: 1.25rem;
    }
    .no-docs-icon {
        font-size: 5rem;
        filter: drop-shadow(0 4px 12px rgba(99,102,241,0.25));
    }
    .no-docs-screen h2 { font-size: 1.8rem; font-weight: 800; color: #1e293b; margin: 0; }
    .no-docs-screen p  { color: #64748b; margin: 0; font-size: 1rem; }
    .upload-cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white !important;
        font-size: 0.95rem;
        font-weight: 600;
        padding: 0.8rem 2rem;
        border-radius: 12px;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(99,102,241,0.35);
        transition: all 0.2s;
    }
    .upload-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(99,102,241,0.45); }

    /* ── Chat Wrapper ── */
