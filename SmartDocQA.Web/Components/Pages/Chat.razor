    /// <summary>Resolves Excel cell references like E46 into "column E, row 46"</summary>
    private string NormalizeQuestion(string q)
    {
        if (SessionState.TabularData == null) return q;

        return CellRefRegex.Replace(q, match =>
        {
            var col = match.Groups[1].Value.ToUpper();
            if (!int.TryParse(match.Groups[2].Value, out int rowNum)) return match.Value;

            // Convert column letter(s) to 0-based index
            int colIdx = 0;
            foreach (char c in col)
                colIdx = colIdx * 26 + (c - 'A' + 1);
            colIdx -= 1; // 0-based

            int dataRowIdx = rowNum - 2; // -1 for 0-based, -1 for header row

            if (colIdx < 0 || colIdx >= SessionState.TabularData.Columns.Count)
                return match.Value;

            var colName = SessionState.TabularData.Columns[colIdx].ColumnName;

            if (dataRowIdx >= 0 && dataRowIdx < SessionState.TabularData.Rows.Count)
            {
                var cellValue = SessionState.TabularData.Rows[dataRowIdx][colIdx]?.ToString() ?? "";
                return $"the value in column \"{colName}\" row {rowNum} (which is \"{cellValue}\")";
            }

            return $"column \"{colName}\" row {rowNum}";
        });
    }

    private bool IsTabularQuestion(string q)
    {
        if (SessionState.TabularData == null) return false;

        var keywords = new[] {
            "sum", "total", "average", "avg", "count", "max", "min", "highest",
            "lowest", "how many", "what is the", "find", "show", "list", "where",
            "which", "filter", "group", "sort", "order", "calculate", "compare",
            "between", "greater", "less than", "equal", "value", "data", "row",
            "column", "excel", "sheet", "table", "record", "entry"
        };
        var lower = q.ToLower();
        return keywords.Any(k => lower.Contains(k)) || CellRefRegex.IsMatch(q);
    }

    private List<string> GetTabularHints()
    {
        if (SessionState.TabularData == null) return new();

        var hints = new List<string>
        {
            $"How many rows are in the data?",
            $"What is the total of the first numeric column?",
            $"Show the first 5 rows"
        };

        // Add column-specific hints
        foreach (System.Data.DataColumn col in SessionState.TabularData.Columns.Cast<System.Data.DataColumn>().Take(2))
        {
            hints.Add($"List all unique values in \"{col.ColumnName}\"");
        }

        return hints.Take(5).ToList();
    }

    private string GetDataSourceSummary()
    {
        var parts = new List<string>();
        if (SessionState.TabularData != null)
            parts.Add($"{(SessionState.TabularFileType == "Excel" ? "📊" : "📋")} {SessionState.TabularDocument?.FileName}");
        if (SessionState.ExtractedDocuments.Any())
            parts.Add($"📄 {SessionState.ExtractedDocuments.Count} doc(s)");
        return parts.Any() ? string.Join(" · ", parts) : "No documents";
    }

    private string GetFileIcon(string fileType) => fileType.ToLower() switch
    {
        "pdf"  => "📄",
        "docx" => "📝",
        "txt"  => "📃",
        "png" or "jpg" or "jpeg" => "🖼️",
        "xlsx" or "xls" => "📊",
        "csv"  => "📋",
        _ => "📁"
    };

    private string FormatAIResponse(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";

        // Escape HTML first
        text = System.Net.WebUtility.HtmlEncode(text);

        // Code blocks ```...```
        text = Regex.Replace(text, @"```([\s\S]*?)```",
            m => $"<pre><code>{m.Groups[1].Value}</code></pre>");

        // Inline code `...`
        text = Regex.Replace(text, @"`([^`]+)`",
            m => $"<code>{m.Groups[1].Value}</code>");

        // Bold **...**
        text = Regex.Replace(text, @"\*\*(.+?)\*\*",
            m => $"<strong>{m.Groups[1].Value}</strong>");

        // Newlines
        text = text.Replace("\n", "<br>");

        return text;
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "var el = document.getElementById('chatScrollArea'); if(el) el.scrollTop = el.scrollHeight;");
        }
        catch { }
    }
