@code {
    private bool IsKeyLoaded(string keyName)
    {
        return !string.IsNullOrEmpty(Environment.GetEnvironmentVariable(keyName));
    }

    private bool AreAnyKeysLoaded()
    {
        return IsKeyLoaded("GROQ_API_KEY") || IsKeyLoaded("OPENAI_API_KEY") || IsKeyLoaded("GOOGLE_API_KEY");
    }

    private string GetProviderChipClass(AIProvider provider)
    {
        return provider switch
        {
            AIProvider.OpenAI => "provider-chip-lg chip-lg-openai",
            AIProvider.Google => "provider-chip-lg chip-lg-google",
            AIProvider.Groq   => "provider-chip-lg chip-lg-groq",
            AIProvider.Ollama => "provider-chip-lg chip-lg-ollama",
            _ => "provider-chip-lg chip-lg-ollama"
        };
    }

    private bool IsDataLoaded()
    {
        return SessionState.TabularData != null || SessionState.ExtractedDocuments.Any();
    }

    private string GetStepClass(int step)
    {
        bool hasDocs = SessionState.ExtractedDocuments.Any() || SessionState.TabularData != null;

        if (step == 1) return !hasDocs ? "active" : "completed";
        if (step == 2) return hasDocs ? "completed" : "";
        if (step == 3) return hasDocs ? "active" : "";
        return "";
    }
}
