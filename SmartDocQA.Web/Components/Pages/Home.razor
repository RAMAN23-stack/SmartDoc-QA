@page "/"
@using SmartDocQA.Core.Models
@inject DocumentSessionState SessionState

<PageTitle>SmartDoc QA — AI Document Intelligence</PageTitle>

<!-- ===== HERO ===== -->
<div class="hero-wrap">
    <div class="hero-glow-1"></div>
    <div class="hero-glow-2"></div>
    <div class="hero-content">
        <div class="hero-badge">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size:0.85rem;" />
            <span>Multi-Provider AI &nbsp;·&nbsp; RAG Search &nbsp;·&nbsp; Secure Keys</span>
        </div>
        <h1 class="hero-title">
            Intelligent Document<br />
            <span class="hero-gradient-text">Question &amp; Answer</span>
        </h1>
        <p class="hero-subtitle">
            Upload any document — PDF, Excel, images — and get AI-powered answers instantly.
            Powered by Groq, OpenAI, and Google Gemini.
        </p>
        <div class="hero-actions">
            <a href="/upload" class="hero-btn-primary">
                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Style="font-size:1rem;" />
                Get Started
            </a>
            <a href="/chat" class="hero-btn-ghost">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Style="font-size:1rem;" />
                Open Chat
            </a>
        </div>
    </div>
</div>

<!-- ===== API KEY STATUS ===== -->
<div class="section-row">
    <div class="glass-card key-status-card @(AreAnyKeysLoaded() ? "keys-ok" : "keys-warn")">
        <div class="key-card-header">
            <MudIcon Icon="@Icons.Material.Filled.VpnKey" Class="key-card-icon" />
            <span class="key-card-title">API Keys</span>
            <span class="key-card-status-badge @(AreAnyKeysLoaded() ? "badge-ok" : "badge-warn")">
                @(AreAnyKeysLoaded() ? "Configured" : "Missing")
            </span>
        </div>
        <div class="key-badges-row">
            <div class="key-badge @(IsKeyLoaded("GROQ_API_KEY") ? "key-loaded" : "key-missing")">
                <span class="key-dot"></span>
                Groq
            </div>
            <div class="key-badge @(IsKeyLoaded("OPENAI_API_KEY") ? "key-loaded" : "key-missing")">
                <span class="key-dot"></span>
                OpenAI
            </div>
            <div class="key-badge @(IsKeyLoaded("GOOGLE_API_KEY") ? "key-loaded" : "key-missing")">
                <span class="key-dot"></span>
                Google
            </div>
        </div>
        @if (!AreAnyKeysLoaded())
        {
            <p class="key-hint">Add your API keys to the <code>.env</code> file to get started.</p>
        }
    </div>

    <!-- Current Provider -->
    <div class="glass-card provider-card">
        <div class="provider-card-header">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Class="provider-card-icon" />
            <span class="provider-card-title">Active Provider</span>
        </div>
        <div class="provider-display">
            <span class="provider-chip-lg @GetProviderChipClass(SessionState.SelectedProvider)">
                @SessionState.SelectedProvider.ToString()
            </span>
            <span class="provider-model-name">@SessionState.SelectedModel</span>
        </div>
        <p class="provider-hint">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Style="font-size:0.8rem;vertical-align:middle;" />
            Switch provider &amp; model from the sidebar
        </p>
    </div>
</div>

<!-- ===== STEP PIPELINE ===== -->
<div class="glass-card pipeline-card">
    <div class="pipeline-header">
        <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="pipeline-icon" />
        <span class="pipeline-title">How It Works</span>
    </div>
    <div class="pipeline-steps">
        <div class="pipeline-step @GetStepClass(1)">
            <div class="step-circle">
                @if (GetStepClass(1) == "completed")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:1rem;color:white;" />
                }
                else
                {
                    <span>1</span>
                }
            </div>
            <div class="step-text">
                <div class="step-name">Upload Files</div>
                <div class="step-desc">PDF, DOCX, Excel, Images</div>
            </div>
        </div>
        <div class="pipeline-connector @(GetStepClass(2) != "" ? "connector-active" : "")"></div>
        <div class="pipeline-step @GetStepClass(2)">
            <div class="step-circle">
                @if (GetStepClass(2) == "completed")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:1rem;color:white;" />
                }
                else
                {
                    <span>2</span>
                }
            </div>
            <div class="step-text">
                <div class="step-name">Process</div>
                <div class="step-desc">Build knowledge base</div>
            </div>
        </div>
        <div class="pipeline-connector @(GetStepClass(3) == "active" ? "connector-active" : "")"></div>
        <div class="pipeline-step @GetStepClass(3)">
            <div class="step-circle">
                @if (GetStepClass(3) == "completed")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size:1rem;color:white;" />
                }
                else
                {
                    <span>3</span>
                }
            </div>
            <div class="step-text">
                <div class="step-name">Ask Questions</div>
                <div class="step-desc">Get AI-powered answers</div>
            </div>
        </div>
    </div>
</div>

<!-- ===== FEATURE CARDS ===== -->
<div class="feature-grid">

    <div class="feature-card fc-blue">
        <div class="fc-icon-wrap">
            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Class="fc-icon" />
        </div>
        <div class="fc-body">
            <div class="fc-title">Upload Documents</div>
            <div class="fc-desc">Support for PDF, DOCX, TXT, Excel, CSV, and Images with AI text extraction.</div>
        </div>
        <a href="/upload" class="fc-btn">
            Upload Now <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Style="font-size:0.9rem;" />
        </a>
    </div>

    <div class="feature-card fc-purple">
        <div class="fc-icon-wrap">
            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="fc-icon" />
        </div>
        <div class="fc-body">
            <div class="fc-title">Ask Questions</div>
            <div class="fc-desc">Semantic RAG search and automated SQLite queries over your document data.</div>
        </div>
        @if (IsDataLoaded())
        {
            <a href="/chat" class="fc-btn">
                Start Chat <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Style="font-size:0.9rem;" />
            </a>
        }
        else
        {
            <div class="fc-btn-disabled">Upload documents first</div>
        }
    </div>

    <div class="feature-card fc-pink">
        <div class="fc-icon-wrap">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Class="fc-icon" />
        </div>
        <div class="fc-body">
            <div class="fc-title">Configuration</div>
            <div class="fc-desc">Review AI models, capabilities, and tune settings for optimal performance.</div>
        </div>
        <a href="/settings" class="fc-btn">
            Configure <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Style="font-size:0.9rem;" />
        </a>
    </div>

</div>

<!-- ===== CAPABILITIES STRIP ===== -->
<div class="caps-strip">
    <div class="cap-item">
        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Class="cap-icon" />
        <span>PDF &amp; DOCX</span>
    </div>
    <div class="cap-divider"></div>
    <div class="cap-item">
        <MudIcon Icon="@Icons.Material.Filled.TableChart" Class="cap-icon" />
        <span>Excel &amp; CSV</span>
    </div>
    <div class="cap-divider"></div>
    <div class="cap-item">
        <MudIcon Icon="@Icons.Material.Filled.CameraAlt" Class="cap-icon" />
        <span>Image OCR</span>
    </div>
    <div class="cap-divider"></div>
    <div class="cap-item">
        <MudIcon Icon="@Icons.Material.Filled.Storage" Class="cap-icon" />
        <span>SQLite Queries</span>
    </div>
    <div class="cap-divider"></div>
    <div class="cap-item">
        <MudIcon Icon="@Icons.Material.Filled.Hub" Class="cap-icon" />
        <span>Multi-Provider AI</span>
    </div>
    <div class="cap-divider"></div>
    <div class="cap-item">
        <MudIcon Icon="@Icons.Material.Filled.Search" Class="cap-icon" />
        <span>Semantic RAG</span>
    </div>
</div>

<style>
    /* ===== Hero ===== */
    .hero-wrap {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
        border-radius: 20px;
        padding: 56px 48px;
        margin-bottom: 24px;
        text-align: center;
        border: 1px solid rgba(99,102,241,0.2);
    }

    .hero-glow-1 {
        position: absolute; top: -80px; left: 50%; transform: translateX(-60%);
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(99,102,241,0.28) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-glow-2 {
        position: absolute; bottom: -60px; right: 10%;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(139,92,246,0.2) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-content { position: relative; z-index: 1; }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(99,102,241,0.15);
        border: 1px solid rgba(99,102,241,0.3);
        color: #a5b4fc;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 6px 16px;
        border-radius: 999px;
        margin-bottom: 20px;
        letter-spacing: 0.2px;
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        color: #f1f5f9;
        line-height: 1.18;
        margin: 0 0 16px;
        letter-spacing: -1px;
    }

    .hero-gradient-text {
        background: linear-gradient(135deg, #818cf8 0%, #a78bfa 50%, #f472b6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.05rem;
        color: #94a3b8;
        max-width: 560px;
        margin: 0 auto 28px;
        line-height: 1.65;
        font-weight: 400;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .hero-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        padding: 11px 24px;
        border-radius: 10px;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(99,102,241,0.45);
        transition: all 0.25s ease;
        letter-spacing: 0.1px;
    }

    .hero-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(99,102,241,0.55);
        color: white;
    }

    .hero-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.06);
        color: #c7d2fe;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 11px 24px;
        border-radius: 10px;
        text-decoration: none;
        border: 1px solid rgba(99,102,241,0.3);
        transition: all 0.25s ease;
    }

    .hero-btn-ghost:hover {
        background: rgba(99,102,241,0.15);
        color: white;
        border-color: rgba(99,102,241,0.5);
    }

    /* ===== Glass Card ===== */
    .glass-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 1.5px solid rgba(255, 255, 255, 0.5);
        border-radius: 18px;
        box-shadow: 0 8px 32px rgba(31, 38, 135, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.3);
        padding: 24px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glass-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 36px rgba(99, 102, 241, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.5);
        border-color: rgba(99, 102, 241, 0.3);
    }

    .mud-theme-dark .glass-card {
        background: rgba(13, 22, 42, 0.55);
        border-color: rgba(255, 255, 255, 0.07);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .mud-theme-dark .glass-card:hover {
        border-color: rgba(99, 102, 241, 0.35);
        box-shadow: 0 12px 36px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    /* ===== Section Row ===== */
    .section-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
    }

    @@media (max-width: 640px) {
        .section-row { grid-template-columns: 1fr; }
    }

    /* ===== Key Status Card ===== */
    .key-status-card { }
    .keys-ok  { border-left: 4px solid #10b981 !important; }
    .keys-warn { border-left: 4px solid #f59e0b !important; }

    .key-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .key-card-icon { font-size: 1.1rem !important; color: #6366f1; }
    .key-card-title { font-weight: 700; font-size: 0.9rem; color: #1e293b; flex: 1; }
    .mud-theme-dark .key-card-title { color: #e2e8f0; }

    .key-card-status-badge {
        font-size: 0.68rem;
        font-weight: 700;
        padding: 2px 10px;
        border-radius: 999px;
        letter-spacing: 0.3px;
    }

    .badge-ok { background: rgba(16,185,129,0.12); color: #059669; }
    .badge-warn { background: rgba(245,158,11,0.12); color: #d97706; }
    .mud-theme-dark .badge-ok { color: #34d399; }
    .mud-theme-dark .badge-warn { color: #fbbf24; }

    .key-badges-row { display: flex; gap: 8px; flex-wrap: wrap; }

    .key-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 999px;
        border: 1px solid transparent;
    }

    .key-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }

    .key-loaded {
        background: rgba(16,185,129,0.1);
        color: #059669;
        border-color: rgba(16,185,129,0.25);
    }

    .key-missing {
        background: rgba(245,158,11,0.1);
        color: #b45309;
        border-color: rgba(245,158,11,0.25);
    }

    .mud-theme-dark .key-loaded { color: #34d399; }
    .mud-theme-dark .key-missing { color: #fbbf24; }

    .key-hint {
        font-size: 0.78rem;
        color: #64748b;
        margin: 10px 0 0;
    }

    .key-hint code {
        background: rgba(99,102,241,0.1);
        color: #6366f1;
        padding: 1px 5px;
        border-radius: 4px;
        font-size: 0.78rem;
    }

    /* ===== Provider Card ===== */
    .provider-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .provider-card-icon { font-size: 1.1rem !important; color: #8b5cf6; }
    .provider-card-title { font-weight: 700; font-size: 0.9rem; color: #1e293b; }
    .mud-theme-dark .provider-card-title { color: #e2e8f0; }

    .provider-display {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .provider-chip-lg {
        font-size: 0.78rem;
        font-weight: 700;
        padding: 5px 14px;
        border-radius: 999px;
        letter-spacing: 0.2px;
    }

    .chip-lg-openai { background: rgba(16,163,127,0.12); color: #059669; }
    .chip-lg-google { background: rgba(66,133,244,0.12); color: #2563eb; }
    .chip-lg-groq   { background: rgba(245,80,54,0.12);  color: #dc2626; }
    .chip-lg-ollama { background: rgba(99,102,241,0.12); color: #6366f1; }
    .mud-theme-dark .chip-lg-openai { color: #34d399; }
    .mud-theme-dark .chip-lg-google { color: #60a5fa; }
    .mud-theme-dark .chip-lg-groq   { color: #f87171; }
    .mud-theme-dark .chip-lg-ollama { color: #818cf8; }

    .provider-model-name {
        font-size: 0.8rem;
        font-weight: 600;
        color: #475569;
        background: rgba(99,102,241,0.07);
        border: 1px solid rgba(99,102,241,0.15);
        padding: 3px 10px;
        border-radius: 6px;
    }

    .mud-theme-dark .provider-model-name { color: #94a3b8; }

    .provider-hint {
        font-size: 0.76rem;
        color: #94a3b8;
        margin: 0;
    }

    /* ===== Pipeline ===== */
    .pipeline-card { margin-bottom: 16px; }

    .pipeline-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
    }

    .pipeline-icon { font-size: 1.1rem !important; color: #6366f1; }

    .pipeline-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #1e293b;
    }

    .mud-theme-dark .pipeline-title { color: #e2e8f0; }

    .pipeline-steps {
        display: flex;
        align-items: center;
        gap: 0;
        flex-wrap: wrap;
    }

    .pipeline-step {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 10px;
        transition: all 0.3s;
        min-width: 140px;
    }

    .pipeline-step.active .step-circle {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        box-shadow: 0 0 0 4px rgba(99,102,241,0.2);
        animation: pulse-step 2s ease infinite;
    }

    @@keyframes pulse-step {
        0%, 100% { box-shadow: 0 0 0 4px rgba(99,102,241,0.2); }
        50%       { box-shadow: 0 0 0 8px rgba(99,102,241,0.08); }
    }

    .pipeline-step.completed .step-circle {
        background: linear-gradient(135deg, #10b981, #059669);
    }

    .pipeline-step.active { opacity: 1; }
    .pipeline-step.completed { opacity: 1; }
    .pipeline-step:not(.active):not(.completed) { opacity: 0.4; }

    .step-circle {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: #cbd5e1;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem;
        font-weight: 800;
        color: white;
        flex-shrink: 0;
        transition: all 0.3s;
    }

    .mud-theme-dark .step-circle { background: #334155; }

    .step-name {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.2;
    }

    .mud-theme-dark .step-name { color: #e2e8f0; }

    .step-desc {
        font-size: 0.72rem;
        color: #94a3b8;
        margin-top: 2px;
    }

    .pipeline-connector {
        flex: 1;
        height: 2px;
        background: #e2e8f0;
        min-width: 20px;
        border-radius: 999px;
        transition: background 0.4s;
    }

    .mud-theme-dark .pipeline-connector { background: #1e3a5f; }

    .pipeline-connector.connector-active {
        background: linear-gradient(90deg, #10b981, #6366f1);
    }

    /* ===== Feature Grid ===== */
    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 16px;
    }

    @@media (max-width: 768px) {
        .feature-grid { grid-template-columns: 1fr; }
    }

    .feature-card {
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(12px);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 22px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 16px 16px 0 0;
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.1);
    }

    .mud-theme-dark .feature-card {
        background: rgba(13,21,38,0.8);
        border-color: rgba(99,102,241,0.12);
    }

    .fc-blue::before { background: linear-gradient(90deg, #6366f1, #818cf8); }
    .fc-purple::before { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }
    .fc-pink::before { background: linear-gradient(90deg, #ec4899, #f472b6); }

    .fc-icon-wrap {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .fc-blue .fc-icon-wrap { background: rgba(99,102,241,0.1); }
    .fc-purple .fc-icon-wrap { background: rgba(139,92,246,0.1); }
    .fc-pink .fc-icon-wrap { background: rgba(236,72,153,0.1); }

    .fc-icon {
        font-size: 1.3rem !important;
    }

    .fc-blue .fc-icon { color: #6366f1 !important; }
    .fc-purple .fc-icon { color: #8b5cf6 !important; }
    .fc-pink .fc-icon { color: #ec4899 !important; }

    .fc-body { flex: 1; }

    .fc-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 5px;
    }

    .mud-theme-dark .fc-title { color: #e2e8f0; }

    .fc-desc {
        font-size: 0.8rem;
        color: #64748b;
        line-height: 1.55;
    }

    .mud-theme-dark .fc-desc { color: #94a3b8; }

    .fc-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        font-weight: 700;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 8px;
        align-self: flex-start;
        transition: all 0.2s;
        letter-spacing: 0.1px;
    }

    .fc-blue .fc-btn  { background: rgba(99,102,241,0.1); color: #6366f1; }
