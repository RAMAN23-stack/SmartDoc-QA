@code {
    // ── State ─────────────────────────────────────────────────────────
    private bool isProcessing = false;
    private bool freshStartTriggered = false;
    private bool vectorDbBuilt = false;
    private string currentFile = "";
    private string processingStatus = "";
    private int processedCount = 0;
    private int totalFilesSelected = 0;
    private double progressValue = 0;

    // Result tracking
    private record SuccessFile(string Name, long Size);
    private record ErrorFile(string Name, string Error);
    private List<SuccessFile> successFiles = new();
    private List<ErrorFile> errorFiles = new();

    // Allowed extensions
    private static readonly HashSet<string> AllowedExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        "pdf", "docx", "xlsx", "xls", "csv", "txt", "png", "jpg", "jpeg"
    };

    private const long MaxFileSizeBytes = 100L * 1024 * 1024; // 100 MB
    private const int MaxFiles = 10;

    // ── Upload Handler ────────────────────────────────────────────────
    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var allFiles = e.GetMultipleFiles(MaxFiles).ToList();
        if (!allFiles.Any()) return;

        // Reset state
        isProcessing = true;
        freshStartTriggered = true;
        vectorDbBuilt = false;
        processedCount = 0;
        progressValue = 0;
        successFiles.Clear();
        errorFiles.Clear();

        // Validate selection count
        if (e.FileCount > MaxFiles)
        {
            Snackbar.Add($"⚠️ Only the first {MaxFiles} files will be processed (you selected {e.FileCount}).", Severity.Warning);
        }

        totalFilesSelected = allFiles.Count;

        // FRESH START — clear all previous data
        SessionState.ClearAll();
        await VectorStore.ClearAsync();
        SqliteEngine.Clear();

        var newDocs = new List<Document>();

        foreach (var file in allFiles)
        {
            currentFile = file.Name;
            var extension = System.IO.Path.GetExtension(file.Name).TrimStart('.').ToLower();

            processingStatus = $"Validating {file.Name}...";
            StateHasChanged();

            // ── Validation ──────────────────────────────────────────
            // 1. File type check
            if (!AllowedExtensions.Contains(extension))
            {
                errorFiles.Add(new ErrorFile(file.Name, $"Unsupported format: .{extension}"));
                processedCount++;
                UpdateProgress();
                StateHasChanged();
                continue;
            }

            // 2. File size check
            if (file.Size > MaxFileSizeBytes)
            {
                errorFiles.Add(new ErrorFile(file.Name, $"File too large: {FormatFileSize(file.Size)} (max 100 MB)"));
                processedCount++;
                UpdateProgress();
                StateHasChanged();
                continue;
            }

            // ── Processing ──────────────────────────────────────────
            processingStatus = $"Reading {file.Name} ({FormatFileSize(file.Size)})...";
            StateHasChanged();

            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: MaxFileSizeBytes);
                using var ms = new System.IO.MemoryStream();
                await stream.CopyToAsync(ms);
                ms.Position = 0;

                processingStatus = $"Extracting content from {file.Name}...";
                StateHasChanged();

                var doc = await DocumentProcessor.ProcessAsync(ms, file.Name, extension);

                // Handle tabular (Excel/CSV)
                if (extension is "xlsx" or "xls" or "csv")
                {
                    var dt = ConvertToDataTable(doc);
                    SqliteEngine.LoadDataTable(dt);
                    SessionState.SetTabularData(doc, dt, extension is "xlsx" or "xls" ? "Excel" : "CSV");
                    
                    if (!string.IsNullOrWhiteSpace(doc.Content))
                    {
                        newDocs.Add(doc);
                        SessionState.AddExtractedDocument(doc);
                    }
                }
                // Handle images — store raw bytes as base64 for the OCR intelligence route
                else if (extension is "png" or "jpg" or "jpeg" or "bmp" or "tiff" or "webp")
                {
                    ms.Position = 0;
                    var imageBytes = ms.ToArray();
                    var base64 = Convert.ToBase64String(imageBytes);
                    var mime = extension switch
                    {
                        "jpg" or "jpeg" => "image/jpeg",
                        "png"           => "image/png",
                        "bmp"           => "image/bmp",
                        "tiff"          => "image/tiff",
                        "webp"          => "image/webp",
                        _               => "image/png"
                    };
                    SessionState.SetImageDocument(doc, base64, mime);
                    if (!string.IsNullOrWhiteSpace(doc.Content))
                    {
                        newDocs.Add(doc);
                        SessionState.AddExtractedDocument(doc);
                    }
                }
                else
                {
                    if (!string.IsNullOrWhiteSpace(doc.Content))
                    {
                        newDocs.Add(doc);
                        SessionState.AddExtractedDocument(doc);
                    }
                }

                successFiles.Add(new SuccessFile(file.Name, file.Size));
            }
            catch (Exception ex)
            {
                errorFiles.Add(new ErrorFile(file.Name, ex.Message));
            }

            processedCount++;
            UpdateProgress();
            StateHasChanged();
        }

        // ── Build Vector Store ────────────────────────────────────────
        if (newDocs.Any())
        {
            processingStatus = "Building AI knowledge base...";
            StateHasChanged();

            foreach (var doc in newDocs)
            {
                try
                {
                    await VectorStore.AddDocumentAsync(doc);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Embedding warning for {doc.FileName}: {ex.Message}");
                }
            }
        }

        vectorDbBuilt = true;
        isProcessing = false;
        currentFile = "";
        processingStatus = "";
        progressValue = 100;
        SessionState.NotifyStateChanged();
        StateHasChanged();

        // Final snackbar summary
        if (successFiles.Any())
            Snackbar.Add($"✅ {successFiles.Count} file(s) processed successfully!", Severity.Success);
        if (errorFiles.Any())
            Snackbar.Add($"⚠️ {errorFiles.Count} file(s) failed — see error list above.", Severity.Warning);
    }

    private void UpdateProgress()
    {
        progressValue = totalFilesSelected > 0
            ? Math.Round((double)processedCount / totalFilesSelected * 100, 1)
            : 0;
    }

    // ── Helpers ───────────────────────────────────────────────────────

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    private DataTable ConvertToDataTable(Document doc)
    {
        var dt = new DataTable();
        if (!doc.TabularData.Any()) return dt;

        var firstRow = doc.TabularData.First();
        var colKeyMap = new Dictionary<string, string>();
        int fallbackIdx = 0;
        foreach (var key in firstRow.Columns.Keys)
        {
            var trimmed = key.Trim();
            if (string.IsNullOrEmpty(trimmed)) trimmed = $"col_{fallbackIdx}";
            fallbackIdx++;
            var safeName = trimmed;
            int dup = 1;
            while (colKeyMap.ContainsKey(safeName))
                safeName = $"{trimmed}_{dup++}";
            colKeyMap[safeName] = key;
            dt.Columns.Add(safeName, typeof(string));
        }

        foreach (var row in doc.TabularData)
        {
            var dr = dt.NewRow();
            foreach (var col in dt.Columns.Cast<DataColumn>())
            {
                var originalKey = colKeyMap.TryGetValue(col.ColumnName, out var ok) ? ok : col.ColumnName;
                dr[col.ColumnName] = row.Columns.TryGetValue(originalKey, out var val) ? val?.ToString() ?? "" : "";
            }
            dt.Rows.Add(dr);
        }
        return dt;
    }

    private List<object[]> GetPreviewRows()
    {
        if (SessionState.TabularData == null) return new();
        var result = new List<object[]>();
        int maxRows = Math.Min(5, SessionState.TabularData.Rows.Count);
        for (int i = 0; i < maxRows; i++)
        {
            var rowItems = new object[SessionState.TabularData.Columns.Count];
            for (int j = 0; j < SessionState.TabularData.Columns.Count; j++)
                rowItems[j] = SessionState.TabularData.Rows[i][j] ?? "";
            result.Add(rowItems);
        }
        return result;
    }

    private string GetTotalChars()
    {
        var total = SessionState.ExtractedDocuments.Sum(d => d.Content.Length);
        if (SessionState.TabularDocument != null)
            total += SessionState.TabularDocument.Content.Length;
        return total.ToString("N0");
    }

    private string GetFileIcon(string fileType) => fileType.ToLower() switch
    {
        "pdf"                  => "📄",
        "docx"                 => "📝",
        "txt"                  => "📃",
        "png" or "jpg"
            or "jpeg"          => "🖼️",
        "xlsx" or "xls"        => "📊",
        "csv"                  => "📋",
        _                      => "📁"
    };

    private string GetCountLabel(string fileType) => fileType.ToLower() switch
    {
        "pdf" => "Pages",
        "docx" => "Paragraphs",
        "xlsx" or "xls" or "csv" => "Rows",
        "txt" => "Characters",
        "png" or "jpg" or "jpeg" => "Extracted Chars",
        _ => "Count"
    };
}
