@page "/upload"
@using SmartDocQA.Core.Interfaces
@using SmartDocQA.Core.Models
@using SmartDocQA.Infrastructure.AI
@using System.Data
@inject IDocumentProcessor DocumentProcessor
@inject IVectorStore VectorStore
@inject DocumentSessionState SessionState
@inject SqliteQueryEngine SqliteEngine
@inject ISnackbar Snackbar

<PageTitle>Upload - SmartDoc QA</PageTitle>

<!-- Hero -->
<div class="upload-hero mb-6">
    <h2>📤 Upload Your Documents</h2>
    <p>AI-powered document analysis · Up to 10 files · 100 MB each</p>
</div>

<!-- Fresh Start Notice -->
@if (freshStartTriggered)
{
    <MudAlert Severity="Severity.Success" Class="fresh-start-alert mb-4" Dense="false">
        <div class="d-flex flex-column gap-1">
            <strong>🆕 Fresh Start — All Old Data Cleared!</strong>
            <div>✅ Old tabular data removed</div>
            <div>✅ Old vector database deleted</div>
            <div>✅ Processing @totalFilesSelected NEW file(s) only</div>
            <div style="font-size: 0.85rem; opacity: 0.85; margin-top: 4px;">
                Questions will be answered ONLY from these new files
            </div>
        </div>
    </MudAlert>
}

<!-- File Upload Area -->
<MudPaper Class="pa-6 mb-4 upload-card" Elevation="2">
    <div class="drop-zone">
        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.h6" Class="mb-1 font-weight-bold">Drop files here or click to browse</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Hold <kbd>Ctrl</kbd> / <kbd>Cmd</kbd> to select multiple files at once
        </MudText>

        <!-- Supported formats chips -->
        <div class="d-flex flex-wrap justify-center gap-1 mb-4">
            @foreach (var fmt in new[] { "PDF", "DOCX", "XLSX", "XLS", "CSV", "TXT", "PNG", "JPG", "JPEG" })
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="format-chip">@fmt</MudChip>
            }
        </div>

        <InputFile OnChange="@HandleFileUpload"
                   multiple
                   accept=".pdf,.docx,.xlsx,.xls,.csv,.txt,.png,.jpg,.jpeg"
                   id="fileInput"
                   class="hidden-input" />
        <label for="fileInput" class="upload-label mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-elevation-2 @(isProcessing ? "disabled-label" : "")">
            <span class="mud-button-label">@(isProcessing ? "⏳ Processing..." : "📁 Choose Files (up to 10)")</span>
        </label>

        <!-- Limits info -->
        <div class="limits-row mt-3">
            <span class="limit-badge">📂 Max 10 files</span>
            <span class="limit-badge">💾 Max 100 MB each</span>
            <span class="limit-badge">🔒 Secure local processing</span>
        </div>
    </div>

    <!-- Progress Bar -->
    @if (isProcessing)
    {
        <div class="mt-4 progress-section">
            <div class="d-flex justify-space-between align-center mb-1">
                <MudText Typo="Typo.body2" Color="Color.Primary"><strong>🔄 @currentFile</strong></MudText>
                <MudText Typo="Typo.caption">@processedCount / @totalFilesSelected files</MudText>
            </div>
            <MudProgressLinear Color="Color.Primary"
                               Value="@progressValue"
                               Rounded="true"
                               Size="Size.Medium"
                               Class="mb-2" />
            <MudText Typo="Typo.caption" Class="text-center opacity-70">@processingStatus</MudText>
        </div>
    }
</MudPaper>

<!-- Success & Error Lists (shown during/after upload) -->
@if (successFiles.Any() || errorFiles.Any())
{
    <MudGrid Spacing="3" Class="mb-4">
        @if (successFiles.Any())
        {
            <MudItem xs="12" md="@(errorFiles.Any() ? 6 : 12)">
                <MudPaper Class="pa-4 result-card result-success" Elevation="2">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-3">
                        ✅ Successfully Processed (@successFiles.Count)
                    </MudText>
                    @foreach (var f in successFiles)
                    {
                        <div class="result-item success-item">
                            <span class="result-icon">@GetFileIcon(System.IO.Path.GetExtension(f.Name).TrimStart('.'))</span>
                            <div class="result-info">
                                <span class="result-name">@f.Name</span>
                                <span class="result-size">@FormatFileSize(f.Size)</span>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        }

        @if (errorFiles.Any())
        {
            <MudItem xs="12" md="@(successFiles.Any() ? 6 : 12)">
                <MudPaper Class="pa-4 result-card result-error" Elevation="2">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-3">
                        ❌ Failed Files (@errorFiles.Count)
                    </MudText>
                    @foreach (var f in errorFiles)
                    {
                        <div class="result-item error-item">
                            <span class="result-icon">⚠️</span>
                            <div class="result-info">
                                <span class="result-name">@f.Name</span>
                                <span class="result-error-msg">@f.Error</span>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

<!-- Processed Documents -->
@if (SessionState.ExtractedDocuments.Any() || SessionState.TabularData != null)
{
    <!-- Stats Row -->
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="4">
            <div class="stat-card">
                <div class="stat-value">@(SessionState.ExtractedDocuments.Count + (SessionState.TabularData != null ? 1 : 0))</div>
                <div class="stat-label">Documents Loaded</div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="4">
            <div class="stat-card">
                <div class="stat-value">@GetTotalChars()</div>
                <div class="stat-label">Characters Indexed</div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="4">
            <div class="stat-card @(vectorDbBuilt ? "stat-card-success" : "")">
                <div class="stat-value">@(vectorDbBuilt ? "✅" : "⏳")</div>
                <div class="stat-label">@(vectorDbBuilt ? "Vector DB Ready" : "Building...")</div>
            </div>
        </MudItem>
    </MudGrid>

    <!-- Document Cards -->
    <MudText Typo="Typo.h6" Class="mb-3 font-weight-bold">📁 Processed Documents</MudText>
    <MudGrid Spacing="3">
        @if (SessionState.TabularData != null)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="doc-card doc-card-tabular">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                @(SessionState.TabularFileType == "Excel" ? "📊" : "📋")
                                @SessionState.TabularDocument?.FileName
                            </MudText>
                            <MudText Typo="Typo.caption">@SessionState.TabularFileType Data</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">LOADED</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2"><strong>Rows:</strong> @SessionState.TabularData.Rows.Count</MudText>
                        <MudText Typo="Typo.body2"><strong>Columns:</strong> @SessionState.TabularData.Columns.Count</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        @foreach (var doc in SessionState.ExtractedDocuments)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="doc-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@GetFileIcon(doc.FileType) @doc.FileName</MudText>
                            <MudText Typo="Typo.caption">@doc.FileType.ToUpper()</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">INDEXED</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (doc.PageCount > 0)
                        {
                            <MudText Typo="Typo.body2"><strong>@GetCountLabel(doc.FileType):</strong> @doc.PageCount.ToString("N0")</MudText>
                        }
                        <MudText Typo="Typo.body2"><strong>Characters:</strong> @doc.Content.Length.ToString("N0")</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    <!-- Tabular Data Preview -->
    @if (SessionState.TabularData != null)
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-3 font-weight-bold">
            📊 Data Preview (First 5 Rows)
        </MudText>
        <MudPaper Elevation="2" Class="overflow-x-auto">
            <MudTable Items="@GetPreviewRows()" Dense="true" Striped="true" Bordered="true" Elevation="0">
                <HeaderContent>
                    @foreach (DataColumn col in SessionState.TabularData.Columns)
                    {
                        <MudTh>@col.ColumnName</MudTh>
                    }
                </HeaderContent>
                <RowTemplate>
                    @foreach (var val in context)
                    {
                        <MudTd>@val</MudTd>
                    }
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <!-- Column Reference -->
        <div class="columns-info mt-4 pa-4">
            <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">
                📋 Available Columns (exact names):
            </MudText>
            <div class="d-flex flex-wrap gap-2">
                @foreach (DataColumn col in SessionState.TabularData.Columns)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@col.ColumnName</MudChip>
                }
            </div>
            <MudText Typo="Typo.caption" Class="mt-2 opacity-70">
                💡 Tip: Use exact column names or Excel cell references like <strong>E46</strong>, <strong>A10</strong> in the Chat
            </MudText>
        </div>
    }

    <!-- Go To Chat -->
    <div class="text-center mt-6">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Href="/chat"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Chat"
                   Class="go-chat-btn">
            💬 Go to Chat → Ask Questions
        </MudButton>
    </div>
}

